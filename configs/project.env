# Shared configuration for the SmolVLA + LIBERO project.
# Source this file from repo root: source configs/project.env

export VLA_REMOTE_ROOT="${VLA_REMOTE_ROOT:-/root/vla_project}"
export LEROBOT_ROOT="${LEROBOT_ROOT:-/root/vla_project/lerobot}"

export DATA_ROOT="${DATA_ROOT:-/root/autodl-tmp/datasets/HuggingFaceVLA_libero}"
export MODEL_ROOT="${MODEL_ROOT:-/root/autodl-tmp/models/lerobot_smolvla_base}"
export VLM_MODEL_ID="${VLM_MODEL_ID:-HuggingFaceTB/SmolVLM2-500M-Video-Instruct}"
export VLM_ROOT="${VLM_ROOT:-/root/autodl-tmp/models/SmolVLM2-500M-Video-Instruct}"
export OUTPUT_ROOT="${OUTPUT_ROOT:-/root/autodl-tmp/outputs/vla_project}"
export CACHE_ROOT="${CACHE_ROOT:-/root/autodl-tmp/cache}"

export HF_ENDPOINT="${HF_ENDPOINT:-https://hf-mirror.com}"
export HF_HUB_DISABLE_XET="${HF_HUB_DISABLE_XET:-1}"
export HF_HOME="${HF_HOME:-${CACHE_ROOT}/huggingface}"
export HF_HUB_CACHE="${HF_HUB_CACHE:-${HF_HOME}/hub}"
export TRANSFORMERS_CACHE="${TRANSFORMERS_CACHE:-${HF_HOME}/transformers}"
export DATASETS_CACHE="${DATASETS_CACHE:-${HF_HOME}/datasets}"
export TORCH_HOME="${TORCH_HOME:-${CACHE_ROOT}/torch}"

export MUJOCO_GL="${MUJOCO_GL:-egl}"
export PYOPENGL_PLATFORM="${PYOPENGL_PLATFORM:-egl}"
export TOKENIZERS_PARALLELISM="${TOKENIZERS_PARALLELISM:-false}"

export SUITE="${SUITE:-libero_spatial}"
export CONTROL_MODE="${CONTROL_MODE:-relative}"
export N_ACTION_STEPS="${N_ACTION_STEPS:-10}"
export CHUNK_SIZE="${CHUNK_SIZE:-50}"
export ODE_STEPS="${ODE_STEPS:-10}"

export TRAIN_STEPS="${TRAIN_STEPS:-30000}"
export BATCH_SIZE="${BATCH_SIZE:-4}"
export EVAL_EPISODES="${EVAL_EPISODES:-10}"
export EVAL_BATCH_SIZE="${EVAL_BATCH_SIZE:-1}"
export ENV_EVAL_FREQ="${ENV_EVAL_FREQ:-5000}"
export SAVE_FREQ="${SAVE_FREQ:-5000}"

export PROJECT_NAME="${PROJECT_NAME:-smolvla_libero_spatial_expert_only}"
export SPLIT_DIR="${SPLIT_DIR:-${OUTPUT_ROOT}/splits}"
export RESULTS_DIR="${RESULTS_DIR:-${OUTPUT_ROOT}/results}"
export CHECKPOINT_DIR="${CHECKPOINT_DIR:-${OUTPUT_ROOT}/checkpoints/${PROJECT_NAME}}"
